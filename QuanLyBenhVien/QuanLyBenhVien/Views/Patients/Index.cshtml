@model IEnumerable<QuanLyBenhVien.Models.Patient>

<h2>Danh sách bệnh nhân</h2>
<table>
    <thead>
        <tr>
            <th>Mã bệnh nhân</th>
            <th>Người dùng</th>
            <th>Địa chỉ</th>
            <th>Bảo hiểm</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var patient in Model)
        {
            <tr>
                <td>@patient.PatientID</td>
                <td>@patient.UserID</td>
                <td>@patient.Address</td>
                <td>@patient.InsuranceID</td>
                <td>
                    <a href="@Url.Action("Details", "Patients", new { id = patient.PatientID })">Chi tiết</a> |
                    <a href="@Url.Action("Edit", "Patients", new { id = patient.PatientID })">Chỉnh sửa</a> |
                    <a href="@Url.Action("Delete", "Patients", new { id = patient.PatientID })">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
