@{
    ViewData["Title"] = "Trang quản trị";
    Layout = "_Layout";
}

@{
    var stats = ViewBag.Stats as QuanLyBenhVien.Frontend.Models.DashboardStats;
}

<!-- Admin Header -->
<section style="background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); color: white; padding: 40px 0; margin: -40px -15px 40px; border-radius: 0 0 50px 50px;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 style="font-size: 2.5rem; font-weight: 700;"><i class="fas fa-tachometer-alt me-3"></i>Dashboard</h1>
                <p class="mt-2" style="opacity: 0.9;">Chào mừng, @Context.Session.GetString("FullName")! Đây là tổng quan hệ thống.</p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <span class="badge" style="background: #4fc3f7; color: #0f4c75; padding: 10px 20px; font-size: 1rem;">
                    <i class="fas fa-user-shield me-2"></i>Quản trị viên
                </span>
            </div>
        </div>
    </div>
</section>

<!-- Stats Cards -->
<section class="mb-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; border-left: 4px solid #0f4c75;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <div style="width: 60px; height: 60px; background: rgba(15, 76, 117, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-users" style="font-size: 1.5rem; color: #0f4c75;"></i>
                            </div>
                        </div>
                        <div>
                            <p class="text-muted mb-1">Tổng người dùng</p>
                            <h2 style="font-weight: 700; color: #0f4c75; margin: 0;">@(stats?.TotalUsers ?? 0)</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; border-left: 4px solid #11998e;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <div style="width: 60px; height: 60px; background: rgba(17, 153, 142, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-user-md" style="font-size: 1.5rem; color: #11998e;"></i>
                            </div>
                        </div>
                        <div>
                            <p class="text-muted mb-1">Bác sĩ</p>
                            <h2 style="font-weight: 700; color: #11998e; margin: 0;">@(stats?.TotalDoctors ?? 0)</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; border-left: 4px solid #667eea;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <div style="width: 60px; height: 60px; background: rgba(102, 126, 234, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-procedures" style="font-size: 1.5rem; color: #667eea;"></i>
                            </div>
                        </div>
                        <div>
                            <p class="text-muted mb-1">Bệnh nhân</p>
                            <h2 style="font-weight: 700; color: #667eea; margin: 0;">@(stats?.TotalPatients ?? 0)</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; border-left: 4px solid #f59e0b;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <div style="width: 60px; height: 60px; background: rgba(245, 158, 11, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-calendar-check" style="font-size: 1.5rem; color: #f59e0b;"></i>
                            </div>
                        </div>
                        <div>
                            <p class="text-muted mb-1">Lịch hẹn</p>
                            <h2 style="font-weight: 700; color: #f59e0b; margin: 0;">@(stats?.TotalAppointments ?? 0)</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; border-left: 4px solid #dc2626;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <div style="width: 60px; height: 60px; background: rgba(220, 38, 38, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-dollar-sign" style="font-size: 1.5rem; color: #dc2626;"></i>
                            </div>
                        </div>
                        <div>
                            <p class="text-muted mb-1">Doanh thu</p>
                            <h2 style="font-weight: 700; color: #dc2626; margin: 0;">@String.Format("{0:N0} VNĐ", stats?.TotalRevenue ?? 0)</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; border-left: 4px solid #8b5cf6;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <div style="width: 60px; height: 60px; background: rgba(139, 92, 246, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-building" style="font-size: 1.5rem; color: #8b5cf6;"></i>
                            </div>
                        </div>
                        <div>
                            <p class="text-muted mb-1">Phòng ban</p>
                            <h2 style="font-weight: 700; color: #8b5cf6; margin: 0;">@(stats?.TotalDepartments ?? 0)</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Actions -->
<section class="mb-5">
    <div class="container">
        <h4 style="font-weight: 600; color: #0f4c75; margin-bottom: 20px;">
            <i class="fas fa-bolt me-2"></i>Thao tác nhanh
        </h4>
        <div class="row g-3">
            <div class="col-lg-3 col-md-6">
                <a href="/Admin/Patients" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px; transition: all 0.3s ease; cursor: pointer;">
                        <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                            <i class="fas fa-user-injured text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <h6 style="color: #333; font-weight: 600;">Quản lý Bệnh nhân</h6>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">@(stats?.TotalPatients ?? 0) bệnh nhân</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <a href="/Admin/Doctors" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px; transition: all 0.3s ease; cursor: pointer;">
                        <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                            <i class="fas fa-user-md text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <h6 style="color: #333; font-weight: 600;">Quản lý Bác sĩ</h6>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">@(stats?.TotalDoctors ?? 0) bác sĩ</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <a href="#" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px; transition: all 0.3s ease; cursor: pointer;">
                        <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                            <i class="fas fa-calendar-alt text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <h6 style="color: #333; font-weight: 600;">Quản lý Lịch hẹn</h6>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">@(stats?.TotalAppointments ?? 0) lịch hẹn</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <a href="#" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px; transition: all 0.3s ease; cursor: pointer;">
                        <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px;">
                            <i class="fas fa-file-invoice-dollar text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <h6 style="color: #333; font-weight: 600;">Thanh toán</h6>
                        <p class="text-muted mb-0" style="font-size: 0.85rem;">Xem doanh thu</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .card:hover {
        transform: translateY(-5px);
    }
    a:hover .card {
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
</style>
