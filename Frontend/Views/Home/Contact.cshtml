@{
    ViewData["Title"] = "Liên hệ";
    Layout = "_Layout";
}

<!-- Hero -->
<section style="background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); color: white; padding: 80px 0; margin: -40px -15px 40px; border-radius: 0 0 50px 50px;">
    <div class="container text-center">
        <h1 style="font-size: 3rem; font-weight: 700;"><i class="fas fa-headset me-3"></i>Liên hệ</h1>
        <p class="mt-3" style="font-size: 1.2rem; opacity: 0.9;">Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn</p>
    </div>
</section>

<section class="mb-5">
    <div class="container">
        <div class="row g-4">
            <!-- Contact Info -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                    <div class="card-body p-4">
                        <h4 style="color: #0f4c75; font-weight: 600;">Thông tin liên hệ</h4>
                        <p class="text-muted mt-2">Hãy liên hệ với chúng tôi qua các kênh sau:</p>
                        
                        <div class="mt-4">
                            <div class="d-flex align-items-start mb-4">
                                <div class="contact-icon me-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-map-marker-alt text-white"></i>
                                </div>
                                <div>
                                    <h6 style="font-weight: 600; color: #333;">Địa chỉ</h6>
                                    <p class="text-muted mb-0">123 Đường ABC, Quận 1, TP.HCM</p>
                                </div>
                            </div>

                            <div class="d-flex align-items-start mb-4">
                                <div class="contact-icon me-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-phone text-white"></i>
                                </div>
                                <div>
                                    <h6 style="font-weight: 600; color: #333;">Điện thoại</h6>
                                    <p class="text-muted mb-0">0901 234 567</p>
                                    <p class="text-muted mb-0">028 1234 5678</p>
                                </div>
                            </div>

                            <div class="d-flex align-items-start mb-4">
                                <div class="contact-icon me-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-envelope text-white"></i>
                                </div>
                                <div>
                                    <h6 style="font-weight: 600; color: #333;">Email</h6>
                                    <p class="text-muted mb-0">contact@medcare.com</p>
                                    <p class="text-muted mb-0">support@medcare.com</p>
                                </div>
                            </div>

                            <div class="d-flex align-items-start">
                                <div class="contact-icon me-3" style="width: 50px; height: 50px; background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-clock text-white"></i>
                                </div>
                                <div>
                                    <h6 style="font-weight: 600; color: #333;">Giờ làm việc</h6>
                                    <p class="text-muted mb-0">Thứ 2 - Thứ 6: 7:00 - 17:00</p>
                                    <p class="text-muted mb-0">Thứ 7: 7:00 - 12:00</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
                    <div class="card-body p-4">
                        <h4 style="color: #0f4c75; font-weight: 600;">Gửi tin nhắn</h4>
                        <p class="text-muted mt-2">Điền thông tin và chúng tôi sẽ liên hệ lại sớm nhất</p>
                        
                        <form class="mt-4">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label style="font-weight: 500; color: #333;">Họ và tên</label>
                                    <input type="text" class="form-control" placeholder="Nhập họ và tên" style="border-radius: 10px; padding: 12px;">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label style="font-weight: 500; color: #333;">Email</label>
                                    <input type="email" class="form-control" placeholder="Nhập email" style="border-radius: 10px; padding: 12px;">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label style="font-weight: 500; color: #333;">Số điện thoại</label>
                                <input type="tel" class="form-control" placeholder="Nhập số điện thoại" style="border-radius: 10px; padding: 12px;">
                            </div>
                            <div class="mb-3">
                                <label style="font-weight: 500; color: #333;">Chủ đề</label>
                                <select class="form-select" style="border-radius: 10px; padding: 12px;">
                                    <option selected>-- Chọn chủ đề --</option>
                                    <option>Tư vấn khám bệnh</option>
                                    <option>Đặt lịch hẹn</option>
                                    <option>Hỗ trợ kỹ thuật</option>
                                    <option>Góp ý - Phản hồi</option>
                                    <option>Khác</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label style="font-weight: 500; color: #333;">Nội dung</label>
                                <textarea class="form-control" rows="5" placeholder="Nhập nội dung tin nhắn" style="border-radius: 10px;"></textarea>
                            </div>
                            <button type="submit" class="btn" style="background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); color: white; padding: 12px 40px; border-radius: 25px; font-weight: 600;">
                                <i class="fas fa-paper-plane me-2"></i>Gửi tin nhắn
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Map -->
<section class="mb-5">
    <div class="container">
        <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
            <div style="background: #e5e7eb; height: 400px; display: flex; align-items: center; justify-content: center;">
                <div class="text-center">
                    <i class="fas fa-map-marked-alt" style="font-size: 4rem; color: #9ca3af;"></i>
                    <p class="text-muted mt-2">Bản đồ Google Maps</p>
                    <p class="text-muted" style="font-size: 0.9rem;">123 Đường ABC, Quận 1, TP.HCM</p>
                </div>
            </div>
        </div>
    </div>
</section>
