@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_Layout";
}

<!-- Hero Section -->
<section class="hero-section" style="background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); color: white; padding: 80px 0; margin: -40px -15px 40px; border-radius: 0 0 50px 50px;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 20px;">
                    Chăm sóc sức khỏe <span style="color: #4fc3f7;">tận tâm</span>
                </h1>
                <p style="font-size: 1.1rem; opacity: 0.9; margin-bottom: 30px; line-height: 1.8;">
                    Hệ thống quản lý bệnh viện hiện đại, kết nối bệnh nhân với đội ngũ bác sĩ chuyên nghiệp. 
                    Đặt lịch khám dễ dàng, theo dõi sức khỏe tiện lợi.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Account/Register" class="btn btn-lg" style="background: #4fc3f7; color: #0f4c75; font-weight: 600; border-radius: 30px; padding: 12px 30px;">
                        <i class="fas fa-calendar-check me-2"></i> Đặt lịch khám
                    </a>
                    <a href="/Account/Login" class="btn btn-lg btn-outline-light" style="border-radius: 30px; padding: 12px 30px;">
                        <i class="fas fa-sign-in-alt me-2"></i> Đăng nhập
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-4 mt-lg-0">
                <i class="fas fa-heartbeat" style="font-size: 15rem; opacity: 0.3;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats-section mb-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px;">
                    <div class="card-body">
                        <i class="fas fa-user-md" style="font-size: 3rem; color: #0f4c75;"></i>
                        <h3 class="mt-3 mb-1" style="color: #0f4c75; font-weight: 700;">50+</h3>
                        <p class="text-muted mb-0">Bác sĩ chuyên khoa</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px;">
                    <div class="card-body">
                        <i class="fas fa-procedures" style="font-size: 3rem; color: #11998e;"></i>
                        <h3 class="mt-3 mb-1" style="color: #11998e; font-weight: 700;">1000+</h3>
                        <p class="text-muted mb-0">Bệnh nhân tin tưởng</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px;">
                    <div class="card-body">
                        <i class="fas fa-stethoscope" style="font-size: 3rem; color: #667eea;"></i>
                        <h3 class="mt-3 mb-1" style="color: #667eea; font-weight: 700;">20+</h3>
                        <p class="text-muted mb-0">Chuyên khoa</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100 text-center py-4" style="border-radius: 15px;">
                    <div class="card-body">
                        <i class="fas fa-award" style="font-size: 3rem; color: #f59e0b;"></i>
                        <h3 class="mt-3 mb-1" style="color: #f59e0b; font-weight: 700;">10+</h3>
                        <p class="text-muted mb-0">Năm kinh nghiệm</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="services-section mb-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 style="font-weight: 700; color: #0f4c75;">Dịch vụ nổi bật</h2>
            <p class="text-muted">Mang đến trải nghiệm chăm sóc sức khỏe tốt nhất</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; transition: transform 0.3s ease;">
                    <div class="card-body text-center p-4">
                        <div class="icon-box mx-auto mb-4" style="width: 80px; height: 80px; background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-calendar-check" style="font-size: 2rem; color: white;"></i>
                        </div>
                        <h4 style="color: #0f4c75; font-weight: 600;">Đặt lịch khám</h4>
                        <p class="text-muted">Đặt lịch khám online 24/7, chọn bác sĩ và chuyên khoa theo nhu cầu.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; transition: transform 0.3s ease;">
                    <div class="card-body text-center p-4">
                        <div class="icon-box mx-auto mb-4" style="width: 80px; height: 80px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-file-medical" style="font-size: 2rem; color: white;"></i>
                        </div>
                        <h4 style="color: #11998e; font-weight: 600;">Hồ sơ bệnh án</h4>
                        <p class="text-muted">Xem và theo dõi hồ sơ bệnh án điện tử mọi lúc, mọi nơi.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 15px; transition: transform 0.3s ease;">
                    <div class="card-body text-center p-4">
                        <div class="icon-box mx-auto mb-4" style="width: 80px; height: 80px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            <i class="fas fa-video" style="font-size: 2rem; color: white;"></i>
                        </div>
                        <h4 style="color: #667eea; font-weight: 600;">Tư vấn từ xa</h4>
                        <p class="text-muted">Tư vấn bác sĩ qua video call, tiết kiệm thời gian di chuyển.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Departments Section -->
<section class="departments-section mb-5" style="background: #f8fafc; padding: 60px 0; margin: 40px -15px; border-radius: 20px;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 style="font-weight: 700; color: #0f4c75;">Chuyên khoa</h2>
            <p class="text-muted">Đội ngũ bác sĩ giàu kinh nghiệm</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-2 col-md-4 col-6">
                <div class="text-center">
                    <div class="dept-icon mx-auto mb-3" style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                        <i class="fas fa-heart" style="font-size: 1.5rem; color: #dc2626;"></i>
                    </div>
                    <h6 style="font-weight: 600;">Tim mạch</h6>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="text-center">
                    <div class="dept-icon mx-auto mb-3" style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                        <i class="fas fa-brain" style="font-size: 1.5rem; color: #7c3aed;"></i>
                    </div>
                    <h6 style="font-weight: 600;">Thần kinh</h6>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="text-center">
                    <div class="dept-icon mx-auto mb-3" style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                        <i class="fas fa-bone" style="font-size: 1.5rem; color: #0891b2;"></i>
                    </div>
                    <h6 style="font-weight: 600;">Cơ xương khớp</h6>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="text-center">
                    <div class="dept-icon mx-auto mb-3" style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                        <i class="fas fa-child" style="font-size: 1.5rem; color: #f59e0b;"></i>
                    </div>
                    <h6 style="font-weight: 600;">Nhi khoa</h6>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="text-center">
                    <div class="dept-icon mx-auto mb-3" style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                        <i class="fas fa-eye" style="font-size: 1.5rem; color: #059669;"></i>
                    </div>
                    <h6 style="font-weight: 600;">Mắt</h6>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="text-center">
                    <div class="dept-icon mx-auto mb-3" style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                        <i class="fas fa-teeth" style="font-size: 1.5rem; color: #3b82f6;"></i>
                    </div>
                    <h6 style="font-weight: 600;">Răng hàm mặt</h6>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section mb-5">
    <div class="container">
        <div class="card border-0" style="background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); border-radius: 20px; padding: 50px;">
            <div class="row align-items-center">
                <div class="col-lg-8 text-white">
                    <h2 style="font-weight: 700;">Bạn cần hỗ trợ?</h2>
                    <p style="opacity: 0.9; margin-bottom: 0;">Đội ngũ tư vấn của chúng tôi luôn sẵn sàng hỗ trợ 24/7</p>
                </div>
                <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                    <a href="/Home/Contact" class="btn btn-lg" style="background: white; color: #0f4c75; font-weight: 600; border-radius: 30px; padding: 12px 30px;">
                        <i class="fas fa-phone me-2"></i> Liên hệ ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .card:hover {
        transform: translateY(-5px);
    }
</style>
