@{
    ViewData["Title"] = "Giới thiệu";
    Layout = "_Layout";
}

<!-- Hero -->
<section style="background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); color: white; padding: 80px 0; margin: -40px -15px 40px; border-radius: 0 0 50px 50px;">
    <div class="container text-center">
        <h1 style="font-size: 3rem; font-weight: 700;"><i class="fas fa-hospital me-3"></i>Về chúng tôi</h1>
        <p class="mt-3" style="font-size: 1.2rem; opacity: 0.9;">Hệ thống quản lý bệnh viện hiện đại hàng đầu</p>
    </div>
</section>

<!-- About Content -->
<section class="mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4">
                <h2 style="color: #0f4c75; font-weight: 700;">MedCare Hospital</h2>
                <p class="text-muted mt-3" style="line-height: 1.9;">
                    MedCare Hospital là hệ thống quản lý bệnh viện được xây dựng trên nền tảng công nghệ hiện đại, 
                    nhằm mang đến trải nghiệm tốt nhất cho cả bệnh nhân và đội ngũ y tế.
                </p>
                <p class="text-muted" style="line-height: 1.9;">
                    Với hệ thống đặt lịch khám online, quản lý hồ sơ bệnh án điện tử và tư vấn từ xa, 
                    chúng tôi cam kết mang đến dịch vụ chăm sóc sức khỏe tiện lợi và hiệu quả.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="row g-4">
                    <div class="col-6">
                        <div class="card border-0 shadow-sm text-center py-4" style="border-radius: 15px;">
                            <i class="fas fa-award" style="font-size: 3rem; color: #f59e0b;"></i>
                            <h3 class="mt-2 mb-1" style="color: #0f4c75;">10+</h3>
                            <p class="text-muted mb-0">Năm kinh nghiệm</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm text-center py-4" style="border-radius: 15px;">
                            <i class="fas fa-users" style="font-size: 3rem; color: #667eea;"></i>
                            <h3 class="mt-2 mb-1" style="color: #0f4c75;">50+</h3>
                            <p class="text-muted mb-0">Bác sĩ</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm text-center py-4" style="border-radius: 15px;">
                            <i class="fas fa-hospital" style="font-size: 3rem; color: #11998e;"></i>
                            <h3 class="mt-2 mb-1" style="color: #0f4c75;">5+</h3>
                            <p class="text-muted mb-0">Cơ sở</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm text-center py-4" style="border-radius: 15px;">
                            <i class="fas fa-smile" style="font-size: 3rem; color: #f59e0b;"></i>
                            <h3 class="mt-2 mb-1" style="color: #0f4c75;">1000+</h3>
                            <p class="text-muted mb-0">Bệnh nhân</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission -->
<section class="mb-5" style="background: #f8fafc; padding: 60px 0; margin: 0 -15px; border-radius: 20px;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 style="color: #0f4c75; font-weight: 700;">Sứ mệnh của chúng tôi</h2>
        </div>
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 h-100" style="border-radius: 15px; background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%); color: white;">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-heart" style="font-size: 3rem; opacity: 0.8;"></i>
                        <h4 class="mt-3">Chăm sóc tận tâm</h4>
                        <p style="opacity: 0.9;">Đặt sức khỏe và sự hài lòng của bệnh nhân lên hàng đầu.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 h-100" style="border-radius: 15px; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-lightbulb" style="font-size: 3rem; opacity: 0.8;"></i>
                        <h4 class="mt-3">Đổi mới sáng tạo</h4>
                        <p style="opacity: 0.9;">Ứng dụng công nghệ tiên tiến để nâng cao chất lượng dịch vụ.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 h-100" style="border-radius: 15px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-shield-alt" style="font-size: 3rem; opacity: 0.8;"></i>
                        <h4 class="mt-3">Bảo mật tuyệt đối</h4>
                        <p style="opacity: 0.9;">Bảo vệ thông tin sức khỏe của bệnh nhân an toàn nhất.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
