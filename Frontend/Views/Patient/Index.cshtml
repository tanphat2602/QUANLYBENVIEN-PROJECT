@model QuanLyBenhVien.Frontend.Models.Appointment
@{
    ViewData["Title"] = "Trang Bệnh Nhân";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Xin chào, @ViewBag.FullName!</h2>
            <p class="text-muted">Chào mừng bạn đến với cổng thông tin bệnh nhân</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Patient/BookAppointment" class="btn btn-primary-custom">
                <i class="fas fa-calendar-plus me-2"></i>Đặt lịch khám
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3">
                        <i class="fas fa-calendar-check fa-2x"></i>
                    </div>
                    <h3 class="mb-1">@(((List<QuanLyBenhVien.Frontend.Models.Appointment>?)ViewBag.UpcomingAppointments)?.Count ?? 0)</h3>
                    <p class="text-muted mb-0">Lịch hẹn sắp tới</p>
                    <a href="/Patient/Appointments" class="btn btn-sm btn-outline-primary mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="fas fa-file-medical fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Hồ sơ bệnh án</p>
                    <a href="/Patient/MedicalRecords" class="btn btn-sm btn-outline-success mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-info bg-opacity-10 text-info rounded-circle mx-auto mb-3">
                        <i class="fas fa-pills fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Đơn thuốc</p>
                    <a href="/Patient/Prescriptions" class="btn btn-sm btn-outline-info mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-calendar me-2 text-primary"></i>Lịch hẹn sắp tới</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.UpcomingAppointments != null && ((List<QuanLyBenhVien.Frontend.Models.Appointment>)ViewBag.UpcomingAppointments).Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Ngày khám</th>
                                        <th>Giờ</th>
                                        <th>Bác sĩ</th>
                                        <th>Khoa</th>
                                        <th>Loại khám</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var apt in (List<QuanLyBenhVien.Frontend.Models.Appointment>)ViewBag.UpcomingAppointments)
                                    {
                                        <tr>
                                            <td>@apt.AppointmentDate</td>
                                            <td>@apt.TimeSlot</td>
                                            <td>@apt.DoctorName</td>
                                            <td>@apt.DepartmentName</td>
                                            <td>@apt.AppointmentType</td>
                                            <td>
                                                @{
                                                    var statusClass = apt.Status switch
                                                    {
                                                        "Hoàn thành" => "bg-success",
                                                        "Đã xác nhận" => "bg-primary",
                                                        "Chờ xác nhận" => "bg-warning",
                                                        "Đã hủy" => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @statusClass">@apt.Status</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-calendar-times text-muted fa-3x mb-3"></i>
                            <p class="text-muted">Bạn chưa có lịch hẹn nào</p>
                            <a href="/Patient/BookAppointment" class="btn btn-primary-custom">Đặt lịch khám ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-user me-2 text-primary"></i>Thông tin cá nhân</h5>
                </div>
                <div class="card-body">
                    <a href="/Patient/Profile" class="btn btn-outline-primary w-100">
                        <i class="fas fa-edit me-2"></i>Chỉnh sửa hồ sơ
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-question-circle me-2 text-primary"></i>Hỗ trợ</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small">Liên hệ hotline: <strong>1900-xxxx</strong> để được hỗ trợ</p>
                </div>
            </div>
        </div>
    </div>
</div>
