@{
    ViewData["Title"] = "Trang Bác sĩ";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Xin chào, @ViewBag.FullName!</h2>
            <p class="text-muted">Trang quản lý bác sĩ</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3">
                        <i class="fas fa-calendar fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Lịch khám hôm nay</p>
                    <a href="/Doctor/Appointments" class="btn btn-sm btn-outline-primary mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Bệnh nhân của tôi</p>
                    <a href="/Doctor/Patients" class="btn btn-sm btn-outline-success mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-info bg-opacity-10 text-info rounded-circle mx-auto mb-3">
                        <i class="fas fa-file-medical fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Tạo bệnh án</p>
                    <a href="/Doctor/Patients" class="btn btn-sm btn-outline-info mt-2">Bắt đầu khám</a>
                </div>
            </div>
        </div>
    </div>
</div>
