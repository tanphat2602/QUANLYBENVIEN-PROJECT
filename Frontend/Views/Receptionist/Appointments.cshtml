@model IEnumerable<QuanLyBenhVien.Frontend.Models.Appointment>
@{
    ViewData["Title"] = "Quản lý lịch hẹn";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-calendar me-2"></i>Quản lý lịch hẹn</h2>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Giờ</th>
                                <th>Bệnh nhân</th>
                                <th>Bác sĩ</th>
                                <th>Khoa</th>
                                <th>Loại khám</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var apt in Model)
                            {
                                <tr>
                                    <td>@apt.AppointmentDate</td>
                                    <td>@apt.TimeSlot</td>
                                    <td>@apt.PatientName</td>
                                    <td>@apt.DoctorName</td>
                                    <td>@apt.DepartmentName</td>
                                    <td>@apt.AppointmentType</td>
                                    <td>
                                        @{
                                            var statusClass = apt.Status switch
                                            {
                                                "Hoàn thành" => "bg-success",
                                                "Đang khám" => "bg-warning",
                                                "Đã xác nhận" => "bg-primary",
                                                "Chờ xác nhận" => "bg-secondary",
                                                "Đã hủy" => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @statusClass">@apt.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times text-muted fa-4x mb-3"></i>
                    <p class="text-muted">Không có lịch hẹn nào</p>
                </div>
            }
        </div>
    </div>
</div>
