@{
    ViewData["Title"] = "Trang Lễ tân";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Xin chào, @ViewBag.FullName!</h2>
            <p class="text-muted">Trang quản lý lễ tân</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3">
                        <i class="fas fa-list fa-2x"></i>
                    </div>
                    <h3 class="mb-1">@(((List<QuanLyBenhVien.Frontend.Models.QueueItem>?)ViewBag.Queue)?.Count ?? 0)</h3>
                    <p class="text-muted mb-0">Lịch hẹn hôm nay</p>
                    <a href="/Receptionist/Queue" class="btn btn-sm btn-outline-primary mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Bệnh nhân</p>
                    <a href="/Receptionist/Patients" class="btn btn-sm btn-outline-success mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-info bg-opacity-10 text-info rounded-circle mx-auto mb-3">
                        <i class="fas fa-calendar-check fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Lịch hẹn</p>
                    <a href="/Receptionist/Appointments" class="btn btn-sm btn-outline-info mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-danger bg-opacity-10 text-danger rounded-circle mx-auto mb-3">
                        <i class="fas fa-ambulance fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Cấp cứu</p>
                    <a href="/Receptionist/Emergency" class="btn btn-sm btn-outline-danger mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-list me-2 text-primary"></i>Hàng đợi hôm nay</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Queue != null && ((List<QuanLyBenhVien.Frontend.Models.QueueItem>)ViewBag.Queue).Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Giờ</th>
                                        <th>Bệnh nhân</th>
                                        <th>Bác sĩ</th>
                                        <th>Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in (List<QuanLyBenhVien.Frontend.Models.QueueItem>)ViewBag.Queue)
                                    {
                                        <tr>
                                            <td>@item.TimeSlot</td>
                                            <td>
                                                @item.PatientName
                                                @if (item.IsEmergency)
                                                {
                                                    <span class="badge bg-danger ms-1">Cấp cứu</span>
                                                }
                                            </td>
                                            <td>@item.DoctorName</td>
                                            <td>
                                                <span class="badge @(item.Status == "Đang khám" ? "bg-warning" : "bg-info")">@item.Status</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-inbox text-muted fa-3x mb-3"></i>
                            <p class="text-muted">Không có lịch hẹn nào hôm nay</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
