@model IEnumerable<QuanLyBenhVien.Frontend.Models.QueueItem>
@{
    ViewData["Title"] = "Hàng đợi hôm nay";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-list me-2"></i>Hàng đợi hôm nay</h2>
            <p class="text-muted">@DateTime.Now.ToString("dd/MM/yyyy")</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3" style="border-radius: 12px;">
                <div class="card-body">
                    <i class="fas fa-users" style="font-size: 1.5rem; color: #667eea;"></i>
                    <h4 class="mt-2 mb-0" style="color: #0f4c75;">@Model.Count()</h4>
                    <small class="text-muted">Tổng lịch hẹn</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3" style="border-radius: 12px;">
                <div class="card-body">
                    <i class="fas fa-clock" style="font-size: 1.5rem; color: #f59e0b;"></i>
                    <h4 class="mt-2 mb-0" style="color: #0f4c75;">@Model.Count(a => a.Status == "Chờ xác nhận" || a.Status == "Đã xác nhận")</h4>
                    <small class="text-muted">Chờ khám</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3" style="border-radius: 12px;">
                <div class="card-body">
                    <i class="fas fa-stethoscope" style="font-size: 1.5rem; color: #10b981;"></i>
                    <h4 class="mt-2 mb-0" style="color: #0f4c75;">@Model.Count(a => a.Status == "Đang khám")</h4>
                    <small class="text-muted">Đang khám</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center py-3" style="border-radius: 12px;">
                <div class="card-body">
                    <i class="fas fa-check-circle" style="font-size: 1.5rem; color: #6366f1;"></i>
                    <h4 class="mt-2 mb-0" style="color: #0f4c75;">@Model.Count(a => a.Status == "Hoàn thành")</h4>
                    <small class="text-muted">Đã khám</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0">Danh sách bệnh nhân</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>STT</th>
                                <th>Giờ</th>
                                <th>Bệnh nhân</th>
                                <th>Điện thoại</th>
                                <th>Bác sĩ</th>
                                <th>Khoa</th>
                                <th>Trạng thái</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var stt = 1; }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@stt</td>
                                    <td>@item.TimeSlot</td>
                                    <td>
                                        @item.PatientName
                                        @if (item.IsEmergency)
                                        {
                                            <span class="badge bg-danger ms-1">Cấp cứu</span>
                                        }
                                    </td>
                                    <td>@item.PatientPhone</td>
                                    <td>@item.DoctorName</td>
                                    <td>@item.Specialty</td>
                                    <td>
                                        @{
                                            var statusClass = item.Status switch
                                            {
                                                "Đang khám" => "bg-warning",
                                                "Hoàn thành" => "bg-success",
                                                "Đã hủy" => "bg-danger",
                                                _ => "bg-info"
                                            };
                                        }
                                        <span class="badge @statusClass">@item.Status</span>
                                    </td>
                                    <td>
                                        @if (item.Status == "Chờ xác nhận")
                                        {
                                            <form action="/Receptionist/CheckIn" method="post" style="display:inline;">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentID" />
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-check"></i> Check-in
                                                </button>
                                            </form>
                                        }
                                        @if (item.Status == "Đã xác nhận")
                                        {
                                            <form action="/Receptionist/CallPatient" method="post" style="display:inline;">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentID" />
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fas fa-bullhorn"></i> Gọi
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                                stt++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox text-muted fa-4x mb-3"></i>
                    <p class="text-muted">Không có lịch hẹn nào hôm nay</p>
                </div>
            }
        </div>
    </div>
</div>
