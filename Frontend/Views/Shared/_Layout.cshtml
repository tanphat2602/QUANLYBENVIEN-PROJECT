<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ thống Quản lý Bệnh viện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f8fafc;
        }

        .navbar {
            background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%);
            padding: 15px 0;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: white !important;
        }

        .navbar-brand i {
            color: #4fc3f7;
            margin-right: 10px;
        }

        .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            transition: all 0.3s ease;
            margin-right: 5px;
        }

        .nav-link:hover {
            color: #4fc3f7 !important;
        }

        .navbar-toggler {
            border-color: rgba(255,255,255,0.5);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 255, 255, 0.9%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            background: #4fc3f7;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0f4c75;
            font-weight: 600;
        }

        .body-content {
            min-height: calc(100vh - 200px);
            padding: 40px 0;
        }

        footer {
            background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%);
            color: white;
            padding: 40px 0 20px;
        }

        footer h5 {
            color: #4fc3f7;
            font-weight: 600;
            margin-bottom: 20px;
        }

        footer a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        footer a:hover {
            color: #4fc3f7;
        }

        footer .social-icons a {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 10px;
            transition: all 0.3s ease;
        }

        footer .social-icons a:hover {
            background: #4fc3f7;
            color: #0f4c75;
        }

        footer .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: 30px;
            padding-top: 20px;
            text-align: center;
            color: rgba(255,255,255,0.6);
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, #0f4c75 0%, #1b6ca8 100%);
            border: none;
            padding: 10px 25px;
            border-radius: 25px;
            color: white;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(15, 76, 117, 0.3);
            color: white;
        }

        .btn-outline-custom {
            border: 2px solid #0f4c75;
            color: #0f4c75;
            padding: 10px 25px;
            border-radius: 25px;
            font-weight: 500;
            background: transparent;
            transition: all 0.3s ease;
        }

        .btn-outline-custom:hover {
            background: #0f4c75;
            color: white;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            @{
                var role = Context.Session.GetString("Role") ?? "";
                var dashboardUrl = role.ToUpperInvariant() switch
                {
                    "ADMIN" => "/Admin/Dashboard",
                    "DOCTOR" => "/Doctor/Index",
                    "PATIENT" => "/Patient/Index",
                    "RECEPTIONIST" => "/Receptionist/Index",
                    "PHARMACIST" => "/Pharmacist/Index",
                    _ => "/"
                };
            }
            <a class="navbar-brand" href="@dashboardUrl">
                <i class="fas fa-hospital-alt"></i>
                MedCare Hospital
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (role == "PATIENT")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Patient/Index"><i class="fas fa-home me-1"></i> Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Patient/BookAppointment"><i class="fas fa-calendar-plus me-1"></i> Đặt lịch khám</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Patient/Appointments"><i class="fas fa-calendar-check me-1"></i> Lịch hẹn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Patient/MedicalRecords"><i class="fas fa-file-medical me-1"></i> Hồ sơ bệnh án</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Patient/Prescriptions"><i class="fas fa-pills me-1"></i> Đơn thuốc</a>
                        </li>
                    }
                    else if (role == "DOCTOR")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Doctor/Index"><i class="fas fa-home me-1"></i> Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Doctor/Appointments"><i class="fas fa-calendar me-1"></i> Lịch khám</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Doctor/Patients"><i class="fas fa-users me-1"></i> Bệnh nhân</a>
                        </li>
                    }
                    else if (role == "RECEPTIONIST")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Receptionist/Index"><i class="fas fa-home me-1"></i> Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Receptionist/Queue"><i class="fas fa-list me-1"></i> Hàng đợi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Receptionist/Patients"><i class="fas fa-users me-1"></i> Bệnh nhân</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Receptionist/Appointments"><i class="fas fa-calendar me-1"></i> Lịch hẹn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Receptionist/Emergency"><i class="fas fa-ambulance me-1"></i> Cấp cứu</a>
                        </li>
                    }
                    else if (role == "PHARMACIST")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Pharmacist/Index"><i class="fas fa-home me-1"></i> Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Pharmacist/Medicines"><i class="fas fa-pills me-1"></i> Kho thuốc</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Pharmacist/PendingPrescriptions"><i class="fas fa-prescription me-1"></i> Đơn thuốc chờ</a>
                        </li>
                    }
                    else if (role == "ADMIN")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Dashboard"><i class="fas fa-home me-1"></i> Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Patients"><i class="fas fa-users me-1"></i> Bệnh nhân</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/List"><i class="fas fa-user-md me-1"></i> Bác sĩ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Medicines"><i class="fas fa-pills me-1"></i> Thuốc</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/Appointments"><i class="fas fa-calendar me-1"></i> Lịch hẹn</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/"><i class="fas fa-home me-1"></i> Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/About"><i class="fas fa-info-circle me-1"></i> Giới thiệu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Contact"><i class="fas fa-phone me-1"></i> Liên hệ</a>
                        </li>
                    }
                </ul>

                @if (Context.Session.GetString("Token") != null)
                {
                    <div class="user-info">
                        <div class="user-avatar">
                            @{
                                var fullName = Context.Session.GetString("FullName") ?? "";
                                var initial = !string.IsNullOrEmpty(fullName) ? fullName[0].ToString().ToUpper() : "U";
                            }
                            @initial
                        </div>
                        <span class="text-white">@fullName</span>
                        <a href="/Account/Logout" class="nav-link btn btn-sm btn-light text-dark ms-2">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2">
                        <a href="/Account/Login" class="btn btn-sm btn-light text-dark">
                            <i class="fas fa-sign-in-alt me-1"></i> Đăng nhập
                        </a>
                        <a href="/Account/Register" class="btn btn-sm btn-primary-custom">
                            <i class="fas fa-user-plus me-1"></i> Đăng ký
                        </a>
                    </div>
                }
            </div>
        </div>
    </nav>

    <div class="body-content">
        <div class="container">
            @RenderBody()
        </div>
    </div>

    <footer>
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h5><i class="fas fa-hospital-alt me-2"></i> MedCare Hospital</h5>
                    <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem;">
                        Hệ thống quản lý bệnh viện hiện đại, mang đến dịch vụ chăm sóc sức khỏe tốt nhất cho bệnh nhân.
                    </p>
                    <div class="social-icons mt-3">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 mb-4">
                    <h5>Dịch vụ</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Khám bệnh</a></li>
                        <li class="mb-2"><a href="#">Đặt lịch hẹn</a></li>
                        <li class="mb-2"><a href="#">Tư vấn bác sĩ</a></li>
                        <li class="mb-2"><a href="#">Gói khám sức khỏe</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 mb-4">
                    <h5>Chuyên khoa</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="#">Nội tổng hợp</a></li>
                        <li class="mb-2"><a href="#">Ngoại tổng hợp</a></li>
                        <li class="mb-2"><a href="#">Tim mạch</a></li>
                        <li class="mb-2"><a href="#">Nhi khoa</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 mb-4">
                    <h5>Liên hệ</h5>
                    <ul class="list-unstyled" style="color: rgba(255,255,255,0.7);">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2"></i> 123 Đường ABC, Quận 1, TP.HCM</li>
                        <li class="mb-2"><i class="fas fa-phone me-2"></i> 0901 234 567</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2"></i> contact@medcare.com</li>
                        <li class="mb-2"><i class="fas fa-clock me-2"></i> Thứ 2 - Thứ 7: 7:00 - 17:00</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year MedCare Hospital. Tất cả quyền được bảo lưu.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
