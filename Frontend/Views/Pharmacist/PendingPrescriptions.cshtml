@{
    ViewData["Title"] = "Đơn thuốc chờ cấp phát";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-prescription me-2"></i>Đơn thuốc chờ cấp phát</h2>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <p class="text-muted">Danh sách đơn thuốc đang chờ được cấp phát.</p>
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>
                Chức năng cấp phát thuốc đang trong quá trình phát triển.
            </div>
        </div>
    </div>
</div>
