@{
    ViewData["Title"] = "Trang Dược sĩ";
    Layout = "_Layout";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Xin chào, @ViewBag.FullName!</h2>
            <p class="text-muted">Trang quản lý dược sĩ</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3">
                        <i class="fas fa-pills fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Kho thuốc</p>
                    <a href="/Pharmacist/Medicines" class="btn btn-sm btn-outline-primary mt-2">Quản lý</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-3">
                        <i class="fas fa-prescription fa-2x"></i>
                    </div>
                    <h3 class="mb-1">@(((List<object>?)ViewBag.PendingPrescriptions)?.Count ?? 0)</h3>
                    <p class="text-muted mb-0">Đơn chờ cấp phát</p>
                    <a href="/Pharmacist/PendingPrescriptions" class="btn btn-sm btn-outline-warning mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="fas fa-chart-bar fa-2x"></i>
                    </div>
                    <h3 class="mb-1"><i class="fas fa-clock"></i></h3>
                    <p class="text-muted mb-0">Báo cáo</p>
                    <a href="/Pharmacist/Medicines" class="btn btn-sm btn-outline-success mt-2">Xem chi tiết</a>
                </div>
            </div>
        </div>
    </div>
</div>
